---
import Base from "../../layouts/Base.astro";
import { url } from "../../config";
import { getCollection } from "astro:content";

const showDrafts = import.meta.env.DEV;
const tutorials = (await getCollection("tutorials"))
  .filter((e) => showDrafts || !e.data.draft)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---
<Base title="Tutorials">
  <section class="page-head">
    <h1>Tutorials</h1>
    <p>Step-by-step write-ups on things I've figured out.</p>
  </section>
  {tutorials.length > 0 ? (
    <ul class="tutorial-list">
      {tutorials.map((t) => (
        <li>
          <a href={url(`/tutorials/${t.id}/`)}>
            <span class="tutorial-title">{t.data.title}</span>
            <span class="tutorial-summary">{t.data.summary}</span>
            {t.data.tags && t.data.tags.length > 0 && (
              <span class="tutorial-tags">{t.data.tags.join(", ")}</span>
            )}
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="empty-state">No tutorials yet. Add a markdown file under <code>content/tutorials/</code>.</p>
  )}
</Base>
