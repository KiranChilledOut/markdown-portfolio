---
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const showDrafts = import.meta.env.DEV;
const projects = (await getCollection("projects"))
  .filter((e) => showDrafts || !e.data.draft)
  .sort((a, b) => {
    const da = a.data.date ? a.data.date.getTime() : 0;
    const db = b.data.date ? b.data.date.getTime() : 0;
    return db - da;
  });
---
<Base title="Projects">
  <section class="page-head">
    <h1>Projects</h1>
    <p>Things I've designed, built, and shipped.</p>
  </section>
  {projects.length > 0 ? (
    <div class="grid">
      {projects.map((p) => <ProjectCard project={p} />)}
    </div>
  ) : (
    <p class="empty-state">No projects published yet. Add a markdown file under <code>content/projects/</code>.</p>
  )}
</Base>
