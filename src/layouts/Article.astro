---
import Base from "./Base.astro";
import { url } from "../config";
import { categoryIcon, categoryClass, statusClass } from "../lib/project-meta";

interface Props {
  title: string;
  summary?: string;
  date?: Date;
  tech?: string[];
  tags?: string[];
  category?: string;
  status?: string;
  links?: { github?: string | null; live?: string | null };
  backUrl: string;
  backLabel: string;
}
const { title, summary, date, tech, tags, category, status, links, backUrl, backLabel } = Astro.props;
const cat = categoryClass(category ?? "");
const iconSvg = categoryIcon(category);
---
<Base title={title}>
  <article class={`article ${cat}`}>
    <header class="article-head">
      {(category || status) && (
        <div class="article-meta-row">
          {category && (
            <span class="article-category">
              <span class="article-category-icon" set:html={iconSvg} />
              {category}
            </span>
          )}
          {status && <span class={`article-status ${statusClass(status)}`}>{status}</span>}
        </div>
      )}
      {date && <p class="article-date">{date.toISOString().slice(0, 10)}</p>}
      <h1>{title}</h1>
      {summary && <p class="article-summary">{summary}</p>}
      {tech && tech.length > 0 && (
        <ul class="tags">
          {tech.map((t) => <li>{t}</li>)}
        </ul>
      )}
      {tags && tags.length > 0 && (
        <ul class="tags">
          {tags.map((t) => <li>#{t}</li>)}
        </ul>
      )}
      {(links?.live || links?.github) && (
        <div class="article-links">
          {links?.live && <a class="btn btn-primary" href={links.live} target="_blank" rel="noopener">Live demo ↗</a>}
          {links?.github && <a class="btn btn-ghost" href={links.github} target="_blank" rel="noopener">Source code ↗</a>}
        </div>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
    <footer class="article-foot">
      <a href={url(backUrl)}>← Back to {backLabel}</a>
    </footer>
  </article>
</Base>
